# emacs keybinds in zsh
bindkey -e

# Keep 1000 lines of history within the shell and save it to ~/.zsh_history:
export HISTSIZE=10000
export SAVEHIST=10000
export HISTFILE=~/.zsh_history

setopt INC_APPEND_HISTORY   # Write each command to the file immediately
setopt SHARE_HISTORY         # Read new commands from the file too (implies INC_APPEND_HISTORY)

# need to explicity enable editor functionality in zsh
autoload -U edit-command-line
zle -N edit-command-line
bindkey '^g' edit-command-line

alias vim=nvim
alias ls='eza -lh --group-directories-first'

export EDITOR=nvim
export VISUAL=nvim

export FZF_DEFAULT_OPTS="$FZF_DEFAULT_OPTS \
                         --highlight-line \
                         --info=inline-right \
                         --ansi \
                         --layout=reverse \
                         --border=none \
    --color=bg+:#b7c1e3,bg:#e1e2e7,spinner:#9854f1,hl:#c64343 \
    --color=fg:#3760bf,header:#2e7de9,info:#2e7de9,pointer:#c64343 \
    --color=marker:#007197,fg+:#3760bf,prompt:#c64343,hl+:#c64343 \
    --color=selected-bg:#b7c1e3 \
    --color=border:#a1a6c5,label:#3760bf"

# Set up fzf key bindings and fuzzy completion
source <(fzf --zsh)
eval "$(starship init zsh)"
eval "$(/Users/yiyuanh/.local/bin/mise activate zsh)"
eval "$(zoxide init zsh)"
