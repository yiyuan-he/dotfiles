# emacs keybinds in zsh
bindkey -e

# need to explicity enable editor functionality in zsh
autoload -z edit-command-line
zle -N edit-command-line
bindkey "^X^E" edit-command-line

alias vim=nvim
alias ls='eza -lh --group-directories-first'

export EDITOR=nvim
export VISUAL=nvim

export FZF_DEFAULT_OPTS="$FZF_DEFAULT_OPTS \
                         --highlight-line \
                         --info=inline-right \
                         --ansi \
                         --layout=reverse \
                         --border=none \
    --color=bg+:#6C6B9B,bg:#121315,spinner:#a8a6f5,hl:#ba5f60 \
    --color=fg:#adadcc,header:#95b1fc,info:#95b1fc,pointer:#ba5f60 \
    --color=marker:#9bbdb8,fg+:#adadcc,prompt:#ba5f60,hl+:#ba5f60 \
    --color=selected-bg:#6C6B9B \
    --color=border:#666a82,label:#adadcc"

# Update tmux environment if inside tmux session
                         if [ -n "$TMUX" ]; then
                         tmux set-environment -g FZF_DEFAULT_OPTS "$FZF_DEFAULT_OPTS"
                         fi

# Set up fzf key bindings and fuzzy completion
source <(fzf --zsh)

    eval "$(starship init zsh)"
    eval "$(/Users/yiyuanh/.local/bin/mise activate zsh)"
    eval "$(zoxide init zsh)"
