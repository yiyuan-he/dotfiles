#!/bin/bash

# Theme switcher for multiple colorschemes
# Updates: Ghostty, tmux, FZF (zshrc), and nvim

# Resolve symlinks (macOS sed -i doesn't work on symlinks)
resolve_path() {
    local file="$1"
    if [[ -L "$file" ]]; then
        local target
        target="$(readlink "$file")"
        if [[ "$target" == /* ]]; then
            echo "$target"
        else
            echo "$(dirname "$file")/$target"
        fi
    else
        echo "$file"
    fi
}

ZSHRC="$(resolve_path "$HOME/.zshrc")"
TMUX_CONF="$(resolve_path "$HOME/.tmux.conf")"
GHOSTTY_CONF="$(resolve_path "$HOME/.config/ghostty/config")"
NVIM_INIT="$(resolve_path "$HOME/.config/nvim/init.lua")"
MINIMAL_ZSH="$(resolve_path "$HOME/dotfiles/minimal_zsh")"

SCHEMES=("tokyonight-day" "tokyonight-night" "tokyonight-moon" "material-oceanic" "one-half-dark" "nord" "catppuccin-latte" "catppuccin-frappe" "catppuccin-macchiato" "catppuccin-mocha" "seoul256-dark" "seoul256-light" "solarized-light" "github-light" "roseprime" "moon" "hojicha" "iceberg" "gruvbox" "wave" "dragon" "lotus")

usage() {
    echo "Usage: theme <colorscheme>"
    echo ""
    echo "Available colorschemes:"
    for s in "${SCHEMES[@]}"; do
        echo "  $s"
    done
    exit 1
}

